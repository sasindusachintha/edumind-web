PORT=5000

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=edumind
DB_PORT=3306

JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRES_IN=8h

CLIENT_URL=http://localhost:5173

# SMTP (for email OTP delivery)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Twilio (for SMS OTP delivery)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1234567890

# Country code used to normalize local-format phone numbers (e.g. 0771234567)
# into E.164 before they're sent to Twilio. Digits only, no plus sign.
DEFAULT_COUNTRY_CODE=94

# Google reCAPTCHA (server-side secret)
RECAPTCHA_SECRET_KEY=

# Number of days in the past a faculty member may still create/edit
# attendance for. Older dates become view-only. Defaults to 30 if unset.
ATTENDANCE_EDIT_WINDOW_DAYS=30
